import { initializeApp } from "firebase/app";
import { getFirestore, collection, onSnapshot, query, where, updateDoc } from "firebase/firestore";
import { readFile, writeFile, readdir, unlink } from "fs/promises";
import { join, resolve } from "path";

// ENTRY POINT: Replace with your Firebase Web Config
const firebaseConfig = {
  apiKey: "",
  authDomain: "",
  projectId: "",
  storageBucket: "",
  messagingSenderId: "",
  appId: ""
};

const app = initializeApp(firebaseConfig);
const db = getFirestore(app);
const ROOT = process.cwd();
const APP_ID = "idx-bridge-relay";

/**
 * ARCHITECTURAL RULE:
 * This script runs in the IDX background. 
 * ChatGPT sends JSON -> Firebase -> This Script -> Filesystem.
 */

const safePath = (rel: string) => {
  const p = resolve(join(ROOT, rel));
  if (!p.startsWith(ROOT)) throw new Error("PERMISSION_DENIED: Path Traversal");
  return p;
};

const q = query(
  collection(db, 'artifacts', APP_ID, 'public', 'data', 'commands'),
  where("status", "==", "pending")
);

onSnapshot(q, async (snap) => {
  for (const change of snap.docChanges()) {
    if (change.type === "added") {
      const docRef = change.doc.ref;
      const { action, path, content } = change.doc.data();

      try {
        let result = "";
        const target = safePath(path);

        switch (action) {
          case "WRITE":
            await writeFile(target, content, "utf-8");
            result = `SUCCESS: Updated ${path}`;
            break;
          case "READ":
            result = await readFile(target, "utf-8");
            break;
          case "LS":
            const entries = await readdir(target);
            result = entries.join("\n");
            break;
        }

        await updateDoc(docRef, { 
          status: "completed", 
          result, 
          finishedAt: Date.now() 
        });
      } catch (e: any) {
        await updateDoc(docRef, { status: "error", result: e.message });
      }
    }
  }
});
